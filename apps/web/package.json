{
  "name": "orb-integration-hub",
  "version": "0.8.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:secure": "npm run build:secure:dev && npx serve dist/ -p 4200",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless --code-coverage",
    "lint": "ng lint",
    "validate:debug": "node scripts/validate-debug-mode.js",
    "build:secure": "npm run build:secure:dev",
    "build:secure:dev": "npm run build:clean && npm run build:angular && npm run secrets:retrieve:dev && npm run secrets:replace:dev",
    "build:secure:staging": "npm run build:clean && npm run build:angular:prod && npm run secrets:retrieve:staging && npm run secrets:replace:staging",
    "build:secure:prod": "npm run build:clean && npm run build:angular:prod && npm run secrets:retrieve:prod && npm run secrets:replace:prod",
    "build:clean": "rm -rf dist/",
    "build:angular": "ng build",
    "build:angular:prod": "ng build --configuration production",
    "secrets:retrieve": "node scripts/secrets-retrieval.js",
    "secrets:retrieve:dev": "node scripts/secrets-retrieval.js dev",
    "secrets:retrieve:staging": "node scripts/secrets-retrieval.js staging",
    "secrets:retrieve:prod": "node scripts/secrets-retrieval.js prod",
    "secrets:replace": "node scripts/replace-secrets.js",
    "secrets:replace:dev": "node scripts/replace-secrets.js dev",
    "secrets:replace:staging": "node scripts/replace-secrets.js staging",
    "secrets:replace:prod": "node scripts/replace-secrets.js prod",
    "test:secrets": "node scripts/test-replace-secrets.js",
    "postbuild:secure": "echo 'Secure build completed successfully!'",
    "setup-dev": "node scripts/setup-dev-env.js dev",
    "setup-staging": "node scripts/setup-dev-env.js staging",
    "setup-prod": "node scripts/setup-dev-env.js prod",
    "cleanup-env": "node scripts/setup-dev-env.js cleanup",
    "ngrok": "node scripts/start-ngrok.js",
    "start:ngrok": "concurrently \"npm start\" \"npm run ngrok\"",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "e2e:codegen": "playwright codegen http://localhost:4200",
    "e2e:install": "playwright install"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/build": "^21.2.0",
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@fortawesome/angular-fontawesome": "^4.0.0",
    "@fortawesome/fontawesome-svg-core": "^6.5.1",
    "@fortawesome/free-solid-svg-icons": "^6.5.1",
    "@ngrx/effects": "^21.0.1",
    "@ngrx/entity": "^21.0.1",
    "@ngrx/store": "^21.0.1",
    "@ngrx/store-devtools": "^21.0.1",
    "aws-amplify": "^6.6.0",
    "dompurify": "^3.2.6",
    "qrcode": "^1.5.4",
    "rxjs": "^7.8.1",
    "typescript": "^5.9.3",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1000.0",
    "@aws-sdk/client-dynamodb": "^3.1000.0",
    "@aws-sdk/client-secrets-manager": "^3.0.0",
    "@aws-sdk/client-ssm": "^3.0.0",
    "@aws-sdk/client-sts": "^3.1000.0",
    "@aws-sdk/credential-provider-sso": "^3.0.0",
    "@aws-sdk/credential-providers": "^3.1000.0",
    "@playwright/test": "^1.58.2",
    "@types/jasmine": "^5.1.4",
    "@types/jest": "^30.0.0",
    "@types/qrcode": "^1.5.5",
    "angular-eslint": "20.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.22.0",
    "fast-check": "^4.5.3",
    "jasmine-core": "^5.3.0",
    "jest": "^30.3.0",
    "js-yaml": "^4.1.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "ts-jest": "^29.4.6",
    "typescript-eslint": "8.26.0"
  }
}
